function getAvarenDlg() {
  const t = G.knowledge, m = G.mood;
  if (m >= 80) return pick(AVAREN_DLG.possess);
  if (t >= 60 || m >= 60) return pick(AVAREN_DLG.open);
  if (t >= 30 || m >= 30) return pick(AVAREN_DLG.warm);
  return pick(AVAREN_DLG.cold);
}

function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

