function renderCookSelectItems() {
  const container = document.getElementById('cook-select-items');
  container.innerHTML = '';
  let hasAny = false;
  COOK_INGREDIENTS_LIST.forEach(ing => {
    const qty = G[ing.key] || 0;
    if (qty <= 0) return;
    hasAny = true;
    const selected = G.cookSelectedKeys.includes(ing.key);
    const btn = document.createElement('button');
    btn.className = 'csi-item' + (selected ? ' selected' : '');
    btn.innerHTML = `<span class="ci-name">${ing.icon} ${ing.name} x${qty}${selected ? ' ✓' : ''}</span><span class="ci-fx">${ing.fx}</span>`;
    btn.onclick = () => toggleCookIngredient(ing.key);
    container.appendChild(btn);
  });
  if (!hasAny) {
    const p = document.createElement('div');
    p.style.cssText = 'color:#6a5020;font-size:13px;padding:10px 0;text-align:center;';
    p.textContent = '嚗澈銝???函?憌?嚗?';
    container.appendChild(p);
    cookSelectCursor = 0;
  }
  // clamp cursor & ?湔?阡?璅??
  const total = cookSelectGetItems().length;
  if (cookSelectCursor >= total) cookSelectCursor = Math.max(0, total - 1);
  cookSelectUpdateFocus();
}

function updateCookSelectSummary() {
  const summary = document.getElementById('cook-select-summary');
  if (!G.cookSelectedKeys || G.cookSelectedKeys.length === 0) {
    summary.textContent = '?芷????祆???';
    return;
  }
  const total = { avarenHunger: 0, pain: 0, curse: 0, mood: 0 };
  G.cookSelectedKeys.forEach(key => {
    const ing = COOK_INGREDIENTS_LIST.find(i => i.key === key);
    if (ing) for (const [k, v] of Object.entries(ing.effects)) total[k] += v;
  });
  const parts = [];
  if (total.avarenHunger > 0) parts.push(`憌賡?摨?${total.avarenHunger}`);
  if (total.pain < 0)         parts.push(`?潛?${total.pain}`);
  if (total.curse < 0)        parts.push(`閰?${total.curse}`);
  if (total.mood > 0)         parts.push(`敹?+${total.mood}`);
  summary.textContent = '效果：' + parts.join('  ');
}

