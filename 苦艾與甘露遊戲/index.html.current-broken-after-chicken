    if (from === 'forest' || to === 'forest') resetChickenState();
    G.scene = to;
    G.sceneCooldown = 90;
    const pos = startOverride || startPos[to] || startPos.outside;
    G.eldrin.x = pos.x;
    G.eldrin.y = pos.y;
    if (G.mood > 50 && !(G.day === 7 && G.timePeriod === 'morning') && !G.day4AvarenGone) G.avarenScene = to;
    renderScene();
