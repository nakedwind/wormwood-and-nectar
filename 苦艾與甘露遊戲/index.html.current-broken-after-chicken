const SP_CLOSE = SLOT_COUNT + 1; // ???????祆局??
function savePanelUpdateFocus() {
  const slots = document.querySelectorAll('.save-slot');
  slots.forEach((el, idx) => {
    el.classList.toggle('sp-focused', idx + 1 === _spFocusSlot);
    el.querySelectorAll('button').forEach((btn, bi) => {
      btn.classList.toggle('sp-btn-focused', idx + 1 === _spFocusSlot && bi === _spFocusBtn);
    });
  });
  const closeBtn = document.getElementById('save-panel-close');
  if (closeBtn) closeBtn.classList.toggle('sp-btn-focused', _spFocusSlot === SP_CLOSE);
}

function savePanelMoveFocus(dSlot, dBtn) {
  const btnCount = _savePanelMode === 'both' ? 2 : 1;
  if (dSlot !== 0) {
    _spFocusSlot = Math.max(1, Math.min(SP_CLOSE, _spFocusSlot + dSlot));
    if (_spFocusSlot === SP_CLOSE) _spFocusBtn = 0;
  }
  if (dBtn !== 0 && _spFocusSlot !== SP_CLOSE) {
    _spFocusBtn = Math.max(0, Math.min(btnCount - 1, _spFocusBtn + dBtn));
  }
  savePanelUpdateFocus();
}

function savePanelConfirm() {
  if (_spFocusSlot === SP_CLOSE) { closeSavePanel(); return; }
  const data = getSlot(_spFocusSlot);
  if (_savePanelMode === 'both') {
    if (_spFocusBtn === 0) saveToSlot(_spFocusSlot);
    else if (data) loadFromSlot(_spFocusSlot);
  } else {
    if (data) loadFromSlot(_spFocusSlot);
  }
}

