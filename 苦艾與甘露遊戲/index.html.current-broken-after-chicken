    if (blanket) blanket.style.zIndex = '16';
    return;
  }

  ROOM_DEPTH_OBJECTS.forEach(id => {
    const obj = document.getElementById(id);
    if (!obj) return;
    if (!obj.dataset.baseZ) obj.dataset.baseZ = String(parseInt(obj.style.zIndex, 10) || 12);
    const baseZ = parseInt(obj.dataset.baseZ, 10) || 12;
    const top    = parseFloat(obj.style.top)    || 0;
    const height = parseFloat(obj.style.height) || 0;
    const anchor = top + height * (ROOM_DEPTH_ANCHORS[id] || 0.88);
    obj.style.zIndex = G.eldrin.y <= anchor ? String(charZ + 2) : String(Math.min(baseZ, charZ - 1));
