<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>?西????/title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&display=swap');
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: #08060302;
  color: #e8d5a3;
  font-family: 'Noto Serif TC','Microsoft JhengHei',serif;
  display: flex; justify-content: center; align-items: flex-start;
  min-height: 100vh; padding: 12px; user-select: none;
  background: radial-gradient(ellipse at center, #1a1008 0%, #080502 100%);
}
#app { width: 880px; max-width: 100%; }

/* ?? TITLE ?? */
#title-screen {
  display: flex; flex-direction: column; align-items: center;
  background: #0a0704;
}
#title-cover-wrap {
  position: relative;
  width: 640px; max-width: 100%;
}
#title-cover {
  width: 100%; display: block; image-rendering: pixelated;
}
#title-game-title {
  position: absolute; top: 42px; left: 0; right: 0;
  text-align: center;
  font-size: 32px; font-weight: 900; color: #ddeeff;
  letter-spacing: 8px;
  text-shadow: 0 0 12px #aad4ff, 0 0 28px #88bbff, 0 0 55px #5599ee, 0 2px 4px #000;
}
#title-intro {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 420px; text-align: center;
  font-size: 13px; line-height: 2.2; color: #c8ddf0;
  text-shadow: 0 1px 6px #000, 0 0 20px #000;
  pointer-events: none;
}
#title-intro em {
  font-style: normal; color: #f0e0a0;
}
#title-start-btn {
  position: absolute; bottom: 46px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg, #1a4a8a, #0e2a5a);
  border: 1px solid #4a80c0; color: #d0e8ff;
  padding: 12px 0; width: 200px; font-size: 16px; font-family: inherit;
  cursor: pointer; letter-spacing: 4px; white-space: nowrap;
  transition: all 0.2s; border-radius: 24px;
  box-shadow: 0 0 16px rgba(60,120,220,0.4);
}
#title-start-btn:hover {
  background: linear-gradient(135deg, #2a5aaa, #1a3a7a);
  box-shadow: 0 0 28px rgba(60,140,255,0.7);
}
#title-continue-btn {
  position: absolute; bottom: 106px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg, #1a3a1a, #0e220e);
  border: 1px solid #4a904a; color: #a0e0a0;
  padding: 12px 0; width: 200px; font-size: 16px; font-family: inherit;
  cursor: pointer; letter-spacing: 4px; white-space: nowrap;
  transition: all 0.2s; border-radius: 24px;
  box-shadow: 0 0 12px rgba(60,180,60,0.3);
  display: none;
}
#title-continue-btn:hover {
  background: linear-gradient(135deg, #2a5a2a, #1a3a1a);
  box-shadow: 0 0 24px rgba(60,200,60,0.6);
}
#title-start-btn.title-focused {
  box-shadow: 0 0 0 2px #90c0ff, 0 0 28px rgba(60,140,255,0.8);
  background: linear-gradient(135deg, #2a5aaa, #1a3a7a);
}
#title-continue-btn.title-focused {
  box-shadow: 0 0 0 2px #80e080, 0 0 24px rgba(60,200,60,0.8);
  background: linear-gradient(135deg, #2a5a2a, #1a3a1a);
}
.btn-primary {
  background: linear-gradient(135deg, #3e2808, #1e1006);
  border: 1px solid #5a3818; color: #f0d060; padding: 13px 50px;
  font-size: 17px; font-family: inherit; cursor: pointer;
  letter-spacing: 4px; transition: all 0.2s; margin-top: 6px;
}
.btn-primary:hover { background: linear-gradient(135deg, #5a3818, #3a2008); box-shadow: 0 0 20px #6a4010; }

/* ?? GAME SCREEN ?? */
#game-screen { display: none; }

/* TOP HUD */
#hud {
  background: #110d06; border: 1px solid #3a2810; border-bottom: none;
  padding: 7px 14px; display: flex; justify-content: space-between; align-items: center; gap: 8px;
}
.hud-day { font-size: 16px; font-weight: 700; color: #f0d060; }
#time-bar-wrap {
  flex: 1; max-width: 300px;
  background: #1a1208; border: 1px solid #2a1a08; height: 14px; position: relative;
}
#time-bar { height: 100%; background: linear-gradient(90deg, #8a6020, #f0d060); transition: width 0.4s; }
#time-label { position: absolute; inset: 0; display: flex; justify-content: center; align-items: center;
  font-size: 10px; color: #f0e0a0; letter-spacing: 1px; }
.hud-right { display: flex; gap: 12px; align-items: center; }
#blood-moon-badge {
  display: none; font-size: 11px; color: #e04040; border: 1px solid #8a1010;
  padding: 2px 8px; letter-spacing: 2px; background: #1a0606;
  animation: pulse 1.5s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

/* ?? 銵??撅??? */
#blood-moon-7-overlay {
  display: none; position: absolute; inset: 0;
  background: rgba(180, 0, 0, 0.30);
  pointer-events: none; z-index: 45;
  animation: bloodPulse 3s ease-in-out infinite;
}
@keyframes bloodPulse {
  0%,100% { background: rgba(180,0,0,0.28); }
  50%      { background: rgba(180,0,0,0.42); }
}

/* ?? MAIN AREA ?? */
#main-area {
  display: flex; gap: 0;
  border: 1px solid #3a2810; border-top: none;
}

/* ?? SCENE ?? */
#scene-wrap {
  position: relative; width: 640px; min-width: 640px; height: 480px;
  overflow: hidden; background: #080604; flex-shrink: 0;
}
#scene-bg {
  position: absolute; inset: 0; z-index: 0;
  background-size: cover; background-position: center top;
  image-rendering: pixelated;
}
#scene-bg-top {
  position: absolute; inset: 0; z-index: 1;
  background-size: cover; background-position: center top;
  image-rendering: pixelated;
  opacity: 0; pointer-events: none;
}

/* Characters */
.char-wrap {
  position: absolute; overflow: hidden;
  image-rendering: pixelated; cursor: pointer;
  transition: left 0.04s linear, top 0.04s linear;
}
.char-wrap img {
  position: absolute; top: 0; left: 0; height: 100%; width: auto;
  image-rendering: pixelated; display: block;
}
.blink-overlay { display: none; pointer-events: none; position: absolute; left: 0; top: 0; image-rendering: pixelated; }
#cw-eldrin { z-index: 13; }
#cw-avaren { z-index:  9; }
#cw-red    { z-index:  9; }

/* Zone highlight hint */
.zone-hint {
  position: absolute; background: rgba(14,10,4,0.88); border: 1px solid #6a4820;
  color: #f0d060; font-size: 12px; padding: 4px 12px;
  pointer-events: none; z-index: 30; letter-spacing: 1px; white-space: nowrap;
  transform: translateX(-50%);
}
#hint-interact { display: none; }
#hint-scene    { display: none; }
#room-label {
  position: absolute; top: 8px; left: 8px;
  background: rgba(8,5,2,0.80); border: 1px solid #3a2810;
  color: #8a7040; font-size: 11px; padding: 3px 10px;
  letter-spacing: 2px; pointer-events: none; z-index: 5;
}

/* Avaren speech bubble ???蝟餃?閫?*/
#avaren-bubble {
  display: none; position: absolute;
  background: rgba(8,14,36,0.93); border: 1px solid #2a4e96;
  padding: 6px 12px; font-size: 12px; color: #98c0ee;
  white-space: nowrap; pointer-events: none; z-index: 25;
  transform: translateX(-50%);
  border-radius: 10px;
  box-shadow: 0 0 8px rgba(40,80,180,0.25);
}
#avaren-bubble::after {
  content: ''; position: absolute; bottom: -6px; left: 50%;
  transform: translateX(-50%);
  border: 5px solid transparent; border-top-color: #2a4e96; border-bottom: none;
}
/* Reid speech bubble ??蝝蝟餃?閫?*/
#red-bubble {
  display: none; position: absolute;
  background: rgba(28,6,6,0.93); border: 1px solid #7a1a1a;
  padding: 6px 12px; font-size: 12px; color: #e09898;
  white-space: nowrap; pointer-events: none; z-index: 25;
  transform: translateX(-50%);
  border-radius: 10px;
  box-shadow: 0 0 8px rgba(160,30,30,0.25);
}
#red-bubble::after {
  content: ''; position: absolute; bottom: -6px; left: 50%;
  transform: translateX(-50%);
  border: 5px solid transparent; border-top-color: #7a1a1a; border-bottom: none;
}

/* ?? RIGHT PANEL ?? */
#right-panel {
  flex: 1; background: #0c0904; border-left: 1px solid #3a2810;
  display: flex; flex-direction: column; padding: 12px 14px; gap: 12px;
  overflow-y: auto; min-width: 0;
}

/* Avaren status block */
#avaren-block {
  display: flex; gap: 10px; align-items: flex-start;
  background: #120e06; border: 1px solid #2e1e08;
  padding: 10px; border-radius: 1px;
}
#avaren-avatar {
  width: 96px; height: 120px; object-fit: cover; object-position: top center;
  border: 1px solid #3a2810; flex-shrink: 0; image-rendering: auto;
}
#avaren-info { flex: 1; min-width: 0; }
.av-name { font-size: 14px; font-weight: 700; color: #f0c060; margin-bottom: 8px; letter-spacing: 1px; }

/* Stat bars */
.stat-row { display: flex; align-items: center; gap: 6px; margin-bottom: 5px; }
.stat-lbl { font-size: 11px; color: #c0c0b8; font-weight: 700; width: 54px; flex-shrink: 0; white-space: nowrap; }
.stat-bg {
  flex: 1; height: 7px; background: #1a1208; border: 1px solid #2a1a08; overflow: hidden;
}
.stat-fill { height: 100%; transition: width 0.4s; }
.fill-hp      { background: linear-gradient(90deg, #a03020, #e04030); }
.fill-curse   { background: linear-gradient(90deg, #4020a0, #8040e0); }
.fill-mood    { background: linear-gradient(90deg, #208040, #40c060); }
.fill-trust   { background: linear-gradient(90deg, #a07020, #e0b030); }
.fill-pain    { background: linear-gradient(90deg, #6a0010, #c0102a); }
.fill-hunger  { background: linear-gradient(90deg, #607010, #a0b820); }
.fill-fatigue { background: linear-gradient(90deg, #304060, #5070a0); }
.stat-num { font-size: 11px; color: #d0d0c8; font-weight: 600; width: 24px; text-align: right; }

/* Resources */
#res-block { background: #120e06; border: 1px solid #2e1e08; padding: 10px; }
.res-title { font-size: 10px; letter-spacing: 3px; color: #5a4020; margin-bottom: 7px; }
.res-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 8px; }
.res-item { font-size: 12px; color: #c0c0b8; font-weight: 600; }
.res-item b { color: #f0c060; }

/* Time status */
#time-block { background: #120e06; border: 1px solid #2e1e08; padding: 10px; }
.time-title { font-size: 10px; letter-spacing: 3px; color: #5a4020; margin-bottom: 6px; }
#time-clock { font-size: 22px; font-weight: 700; color: #f0c060; letter-spacing: 2px; margin-bottom: 6px; }
#time-remaining { font-size: 11px; color: #b0b0a8; font-weight: 600; margin-bottom: 10px; }
#btn-sleep {
  width: 100%; background: #1a1208; border: 1px solid #3a2810; color: #c0a060;
  padding: 8px; font-family: inherit; font-size: 12px; cursor: pointer;
  letter-spacing: 2px; transition: all 0.2s;
}
#btn-sleep:hover { background: #241a0c; border-color: #5a3818; }

/* ?? TOAST ?? */
#toast-wrap {
  position: absolute; top: 10px; right: 10px; z-index: 80;
  display: flex; flex-direction: column; gap: 6px;
  pointer-events: none;
}
.toast-msg {
  background: rgba(8,5,2,0.88); border: 1px solid #5a3818;
  color: #f0d080; font-size: 13px; font-weight: 700;
  padding: 7px 14px; letter-spacing: 1px;
  animation: toastIn 0.2s ease, toastOut 0.5s ease 2.5s forwards;
}
.toast-sys {
  background: rgba(10,6,18,0.93); border: 1px solid #5040a0;
  color: #c0b0f0; font-size: 12px; font-weight: 600;
  padding: 7px 14px 7px 10px; letter-spacing: 1px;
  display: flex; align-items: center; gap: 7px;
  animation: toastIn 0.2s ease, toastOut 0.5s ease 2.8s forwards;
}
.toast-sys::before {
  content: '??'; font-size: 14px; flex-shrink: 0;
}
@keyframes toastIn  { from{ opacity:0; transform:translateY(-6px); } to{ opacity:1; transform:translateY(0); } }
@keyframes toastOut { from{ opacity:1; } to{ opacity:0; } }

/* ?? SETTINGS ?? */
#settings-btn {
  background: none; border: none; color: #a08040; font-size: 18px;
  cursor: pointer; padding: 2px 6px; line-height: 1;
  transition: color 0.2s; position: relative;
}
#settings-btn:hover { color: #f0c060; }
#settings-panel {
  display: none; position: absolute; top: 38px; right: 0;
  background: #110d06; border: 1px solid #3a2810;
  padding: 14px 16px; min-width: 180px; z-index: 200;
  flex-direction: column; gap: 12px;
}
#settings-panel.open { display: flex; }
.settings-row { display: flex; align-items: center; gap: 8px; }
.settings-label { font-size: 11px; color: #c0a060; letter-spacing: 1px; flex-shrink: 0; }
#settings-vol { width: 80px; height: 4px; accent-color: #c0a060; cursor: pointer; }
#pause-btn {
  width: 100%; background: #1a1208; border: 1px solid #3a2810;
  color: #c0a060; padding: 7px; font-family: inherit; font-size: 12px;
  cursor: pointer; letter-spacing: 2px; transition: all 0.2s;
}
#pause-btn:hover { background: #241a0c; border-color: #5a3818; }
#pause-overlay {
  display: none; position: absolute; inset: 0; z-index: 90;
  background: rgba(0,0,0,0.55); align-items: center; justify-content: center;
}
#pause-overlay.active { display: flex; }
#pause-text {
  font-size: 28px; font-weight: 700; color: #f0c060;
  letter-spacing: 6px; text-shadow: 0 0 20px #80600080;
}

/* Left column (scene + story) */
#left-col { display: flex; flex-direction: column; flex-shrink: 0; }

/* Story box */
#story-block {
  display: none;
  position: absolute; left: 50%; bottom: 28px; z-index: 30;
  width: 430px; max-width: calc(100% - 48px);
  transform: translateX(-50%);
  background: rgba(8, 5, 2, 0.88);
  border: 1px solid #4a3214;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.35);
  padding: 10px 34px 10px 12px;
  min-height: 54px;
  max-height: 112px;
  overflow-y: auto;
  cursor: pointer;
  align-items: center;
  gap: 10px;
  transition: opacity 0.8s ease;
}
#story-portrait {
  width: 64px; height: 64px;
  object-fit: cover; image-rendering: pixelated;
  flex-shrink: 0;
  border: 1px solid #3a2810;
  display: none;
}
#story-main { flex: 1; }
#story-arrow {
  position: absolute; bottom: 8px; right: 12px;
  color: #c0a060; font-size: 14px; animation: arrowBlink 1.2s ease-in-out infinite;
}
@keyframes arrowBlink { 0%,100%{ opacity:1; } 50%{ opacity:0.2; } }
#story-speaker { font-size: 10px; letter-spacing: 3px; color: #a0a098; margin-bottom: 5px; }
#story-text { font-size: 13px; line-height: 1.65; color: #d4d4cc; font-weight: 500; }

/* ?拙?敶?內 */
.item-popup {
  position: absolute; z-index: 50; pointer-events: none;
  font-size: 24px; transform: translateX(-50%);
  animation: itemPop 1.4s ease-out forwards;
}
@keyframes itemPop {
  0%   { opacity: 1; transform: translateX(-50%) translateY(0)    scale(1); }
  15%  { opacity: 1; transform: translateX(-50%) translateY(-22px) scale(1.3); }
  100% { opacity: 0; transform: translateX(-50%) translateY(-32px) scale(1.1); }
}

/* 蝝?蝎橘?銵?? */
#cw-red-fairy {
  position: absolute; z-index: 20; display: none; pointer-events: none;
}
#cw-red-fairy img {
  width: 40px; image-rendering: pixelated; display: block;
  animation: fairyBob 2.5s ease-in-out infinite;
  filter: hue-rotate(300deg) saturate(4) brightness(0.85);
  drop-shadow: drop-shadow(0 0 8px #ff2020);
}

/* 憒移 */
#cw-fairy {
  position: absolute; z-index: 20; display: none; pointer-events: none;
}
#cw-fairy img {
  width: 40px; image-rendering: pixelated; display: block;
  animation: fairyBob 2s ease-in-out infinite;
  filter: drop-shadow(0 0 6px #aaf0ff);
}
@keyframes fairyBob { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-9px); } }

/* Warn */
#warn-box {
  display: none; background: #1e0606; border: 1px solid #5a1010;
  color: #e06040; font-size: 12px; padding: 6px 10px;
}

/* ?? ACTION OVERLAY ?? */
#action-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(4,2,0,0.90); z-index: 100;
  justify-content: center; align-items: center;
}
.act-box {
  background: #120e06; border: 1px solid #4a3010;
  width: 440px; max-width: 95vw; padding: 22px 22px 18px;
}
.act-title { font-size: 11px; letter-spacing: 4px; color: #5a4020; margin-bottom: 6px; }
.act-name  { font-size: 20px; font-weight: 700; color: #f0d060; margin-bottom: 16px; }
.act-list  { display: flex; flex-direction: column; gap: 7px; }
.act-item {
  background: #1a1208; border: 1px solid #3a2810;
  padding: 11px 14px; cursor: pointer; font-family: inherit;
  display: flex; justify-content: space-between; align-items: center;
  transition: all 0.15s;
}
.act-item:hover:not(:disabled) { background: #221a0a; border-color: #5a3818; }
.act-item:disabled { opacity: 0.4; cursor: not-allowed; }
.act-item.kbd-selected:not(:disabled) { background: #2a1e08; border-color: #c08030; outline: none; }
.act-item.kbd-selected:not(:disabled) .a-name { color: #ffd060; }
.act-item .a-name { font-size: 14px; color: #e0e0d8; font-weight: 700; }
.act-item .a-fx   { font-size: 11px; color: #a0a098; letter-spacing: 1px; }
.act-cancel {
  margin-top: 8px; width: 100%; background: transparent; border: 1px solid #2a1e08;
  color: #6a5028; padding: 8px; font-family: inherit; font-size: 12px;
  cursor: pointer; letter-spacing: 3px; transition: all 0.15s;
}
.act-cancel:hover { border-color: #4a3010; color: #9a7040; }
.act-cancel.kbd-selected { border-color: #c08030; color: #9a7040; background: #1a1208; }

/* ?? SAVE PANEL ?? */
#save-panel-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(4,2,0,0.88); z-index: 100;
  justify-content: center; align-items: center;
}
#save-panel {
  background: #120e08; border: 1px solid #6a4820;
  padding: 26px 30px; width: 500px; max-width: calc(100% - 32px);
  border-radius: 16px;
}
#save-panel-title {
  font-size: 13px; letter-spacing: 5px; color: #c8903a;
  text-align: center; margin-bottom: 18px;
  border-bottom: 1px solid #4a3018; padding-bottom: 14px;
}
.save-slots-grid {
  display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;
}
.save-slot {
  background: #1c140a; border: 1px solid #4a3418;
  padding: 12px 16px; border-radius: 10px;
  display: flex; align-items: center; gap: 14px;
}
.save-slot-num {
  font-size: 11px; letter-spacing: 2px; color: #a07840;
  width: 44px; flex-shrink: 0; text-align: center;
}
.save-slot-info {
  font-size: 13px; color: #f0d080; font-weight: 600; flex: 1;
}
.save-slot-date {
  font-size: 10px; color: #907850; letter-spacing: 1px; margin-top: 2px;
}
.save-slot-text { flex: 1; display: flex; flex-direction: column; }
.save-slot-btns {
  display: flex; gap: 6px; flex-shrink: 0;
}
.save-slot-btns button {
  padding: 6px 16px; font-size: 12px; font-family: inherit;
  letter-spacing: 2px; cursor: pointer; border: 1px solid;
  transition: all 0.15s; border-radius: 20px;
}
.btn-save-slot {
  background: #2a1c08; border-color: #c08030 !important; color: #f0c060;
}
.btn-save-slot:hover { background: #3a2810; box-shadow: 0 0 10px rgba(200,130,40,0.5); }
.btn-load-slot {
  background: #0c1a28; border-color: #4090d0 !important; color: #90c8f0;
}
.btn-load-slot:hover { background: #182a3e; box-shadow: 0 0 10px rgba(60,140,220,0.5); }
.btn-load-slot:disabled { opacity: 0.25; cursor: not-allowed; box-shadow: none; }
.save-slot.sp-focused { border-color: #c09040; background: #241a0c; }
.save-slot.sp-focused .btn-save-slot.sp-btn-focused { box-shadow: 0 0 0 2px #f0c060; background: #3a2810; }
.save-slot.sp-focused .btn-load-slot.sp-btn-focused { box-shadow: 0 0 0 2px #60b0f0; background: #1e3450; }
#save-panel-close.sp-btn-focused { border-color: #c08030; color: #c8903a; box-shadow: 0 0 0 2px #c09040; }
#save-panel-close {
  display: block; width: 100%; padding: 10px 0;
  background: transparent; border: 1px solid #4a3018;
  color: #907040; font-size: 12px; font-family: inherit;
  letter-spacing: 4px; cursor: pointer; transition: all 0.2s;
  border-radius: 20px;
}
#save-panel-close:hover { border-color: #c08030; color: #c8903a; }

/* ?? COOK INGREDIENT SELECT ?? */
#cook-select-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(4,2,0,0.90); z-index: 100;
