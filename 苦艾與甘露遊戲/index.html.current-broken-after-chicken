<script>
// ??????????????????????????????????????
//  CONSTANTS
// ??????????????????????????????????????
const SCENE_W = 640, SCENE_H = 480;
const CHAR_H  = 90;
const SPEED   = 3;
const DAY_HOURS = 13; // 07:00 ~ 22:00
const HERB_HARVEST_MAX = 1800; // 30蝘?? 60fps
const FISH_MAX         = 1800; // 30蝘?? 60fps
const RESEARCH_MAX     = 600;  // 10蝘?const COOK_MAX         = 1800; // 30蝘?const CARE_MAX         = 900;  // 15蝘?const DAY_REAL_SECONDS = 480;  // 8???祕??
const MORNING_SECONDS  = 240;  // ????嚗銝?
const START_HOUR = 7;

// ??????????????????????????????????????
//  SPRITE SYSTEM (CSS-based, no canvas)
// ??????????????????????????????????????
const SPRITE_COLS   = 4;  // 璈怠?4甈?= 4???甇?撌?????
const SPRITE_ROWS_N = 3;  // 蝮勗?3??= 3?潸粥頝臬???// 瘥?甈????孵?嚗帖?甈?
const POSE_COL  = { front:0, sideL:1, sideR:2, back:3 };
const POSE_FLIP = { front:false, sideL:false, sideR:false, back:false };
const spriteInfo     = { eldrin:null, avaren:null, red:null };
const blinkSpriteInfo = { eldrin:null, avaren:null };

let chickenInfo = null;

function loadSprites(cb) {
  let n = 0;
  const done = () => { if (++n === 4) cb(); };
  ['eldrin','avaren','red'].forEach(name => {
    const img = document.getElementById('sp-' + name);
    const init = () => {
      const fh = img.naturalHeight / SPRITE_ROWS_N;
      // ?芸??菜葫甈嚗??甈??澆祝?湔餈擃?甇?敶Ｘ嚗?撠梁5甈?      const fw4 = img.naturalWidth / 4;
      const fw5 = img.naturalWidth / 5;
      const cols = (Math.abs(fw5 - fh) < Math.abs(fw4 - fh)) ? 5 : SPRITE_COLS;
      const fw   = img.naturalWidth / cols;
      // blinkCol嚗?洵5甈?撠望?函甈??批??潔蜓??
      const blinkCol = cols > SPRITE_COLS ? cols - 1 : -1;
      spriteInfo[name] = { fw, fh, cols, blinkCol };
      done();
    };
    if (img.complete && img.naturalWidth > 0) init();
    else { img.onload = init; img.onerror = done; }
  });
  // ??璈急??嚗?皜砍??賂?
  const chkImg = document.getElementById('sp-chicken');
  const chkInit = () => {
    const frames = Math.max(1, Math.round(chkImg.naturalWidth / chkImg.naturalHeight));
    chickenInfo = { frames, fw: chkImg.naturalWidth / frames, fh: chkImg.naturalHeight };
    done();
  };
  if (chkImg.complete && chkImg.naturalWidth > 0) chkInit();
  else { chkImg.onload = chkInit; chkImg.onerror = done; }
}

function loadBlinkSprites() {
  ['eldrin','avaren'].forEach(name => {
    const url = 'character_' + name + '_blink.png';
    const tmpImg = new Image();
    tmpImg.onload = () => {
      const main = spriteInfo[name];
      if (!main) return;
      const fullW      = Math.round(main.fw * SPRITE_COLS);
      const fullH      = Math.round(main.fh * SPRITE_ROWS_N);
      const singleColH = Math.round(main.fh * SPRITE_ROWS_N);
      let type;
      if (tmpImg.naturalWidth === fullW && tmpImg.naturalHeight === fullH) {
        type = 'fullsheet';
      } else if (tmpImg.naturalHeight === singleColH && tmpImg.naturalWidth <= Math.round(main.fw * 1.5)) {
        type = 'singlecol';
      } else {
        type = 'singleframe'; // ?桐??澆?
      }
      blinkSpriteInfo[name] = { type, url };
    };
    tmpImg.onerror = () => {};
    tmpImg.src = url;
  });
}

function setChickenFrame(frame, facingLeft, dispH) {
  if (!chickenInfo) return;
  const scale  = dispH / chickenInfo.fh;
  const fw     = chickenInfo.fw * scale;
  const totalW = chickenInfo.fw * chickenInfo.frames * scale;
  const wrap   = document.getElementById('cw-chicken');
  const img    = document.getElementById('sp-chicken');
  wrap.style.width  = fw + 'px';
  wrap.style.height = dispH + 'px';
  img.style.width   = totalW + 'px';
  img.style.height  = dispH + 'px';
  img.style.left    = (-(frame % chickenInfo.frames) * fw) + 'px';
  img.style.top     = '0px';
  wrap.style.transform = facingLeft ? 'scaleX(-1)' : 'scaleX(1)';
}

// dispH: character display height; walkFrame: animation row.
function setPose(name, pose, walkFrame, dispH) {
  const info = spriteInfo[name];
  if (!info) return 0;
  const wrap = document.getElementById('cw-' + name);
  const img  = document.getElementById('sp-' + name);
  const scale  = dispH / info.fh;
  const fw     = info.fw * scale;
  const fh     = dispH;
  const totalH = fh * SPRITE_ROWS_N;
  const cols = info.cols || SPRITE_COLS;
  const totalW = fw * cols;
  const col = POSE_COL[pose];
  const row = (walkFrame || 0) % SPRITE_ROWS_N;
  wrap.style.width   = fw + 'px';
  wrap.style.height  = fh + 'px';
  img.style.width    = totalW + 'px';
  img.style.height   = totalH + 'px';
  img.style.left     = (-col * fw) + 'px';
  img.style.top      = (-row * fh) + 'px';
  wrap.style.transform = POSE_FLIP[pose] ? 'scaleX(-1)' : 'scaleX(1)';
  return fw;
}

function sceneCharH() {
  return (G.scene === 'outside' || G.scene === 'forest') ? CHAR_H * 0.5 : CHAR_H;
}

