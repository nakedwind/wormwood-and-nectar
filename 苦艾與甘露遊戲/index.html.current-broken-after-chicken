function isObstacleAt(x, y) {
  for (const o of (OBSTACLES[G.scene] || [])) {
    if (x >= o.x1 && x <= o.x2 && y >= o.y1 && y <= o.y2) return true;
  }
  return false;
}

function getActiveZone() {
  const el = G.eldrin;
  const zones = ZONES[G.scene] || [];
  for (const z of zones) {
    if (el.x >= z.x1 && el.x <= z.x2 && el.y >= z.y1 && el.y <= z.y2) return z;
  }
  return null;
}

function resetChickenState() {
  G.chicken = { x: 250, y: 180, walkTimer: 0, walkDir: {dx:0,dy:0}, walkFrame: 0, walkTick: 0, facing: 'right', carried: false };
}

function isNearChicken() {
  if (G.scene !== 'forest' || G.timePeriod !== 'morning' || !chickenInfo || G.chicken.carried) return false;
  return Math.hypot(G.eldrin.x - G.chicken.x, G.eldrin.y - G.chicken.y) < 55;
}

function pickupChicken() {
  if (G.carryingSoup) { warn('先放下手上的東西再抱雞。'); return; }
  G.chicken.carried = true;
  G.chicken.walkDir = {dx:0, dy:0};
  G.chicken.walkTimer = 0;
  G.chicken.walkFrame = 0;
  toast('抱起雞');
  renderChars();
}

function dropChicken() {
  if (!G.chicken.carried) return;
  const el = G.eldrin;
  const offsetX = el.pose === 'left' ? -24 : el.pose === 'right' ? 24 : 0;
  G.chicken.carried = false;
  G.chicken.x = Math.max(25, Math.min(615, el.x + offsetX));
  G.chicken.y = Math.max(95, Math.min(470, el.y + 10));
  G.chicken.walkDir = {dx:0, dy:0};
  G.chicken.walkTimer = 45;
  G.chicken.walkFrame = 0;
  toast('放下雞');
  renderChars();
}

function isNearAvaren() {
  return G.avarenScene === G.scene &&
    Math.hypot(G.eldrin.x - G.avaren.x, G.eldrin.y - G.avaren.y) < 60;
}

