//  SOUND EFFECTS  (Web Audio API ??嚗??憭瑼?)
// ??????????????????????????????????????
const SFX = (() => {
  let ctx;
  function ensure() { ctx = ctx || new (window.AudioContext || window.webkitAudioContext)(); return ctx; }
  function tone(freq, type='sine', vol=0.05, delay=0, dur=0.08) {
    try {
      const ac = ensure(); const now = ac.currentTime + delay;
      const o = ac.createOscillator(); const g = ac.createGain();
      o.type = type; o.frequency.value = freq;
      g.gain.setValueAtTime(0, now); g.gain.linearRampToValueAtTime(vol, now + 0.01); g.gain.linearRampToValueAtTime(0, now + dur);
      o.connect(g); g.connect(ac.destination); o.start(now); o.stop(now + dur + 0.02);
    } catch (_) {}
  }
  return {
    click(){ tone(580); }, interact(){ tone(520); }, start(){ tone(360); }, collect(){ tone(660); }, complete(){ tone(784); },
    scene(){ tone(400); }, deny(){ tone(220, 'square'); }, night(){ tone(370); }, morning(){ tone(440); }, bubble(){ tone(1100); }, event(){ tone(550); },
  };
})();

document.addEventListener('click', e => {
  const btn = e.target.closest('button');
  if (btn && !btn.classList.contains('act-item')) SFX.click();
}, true);

