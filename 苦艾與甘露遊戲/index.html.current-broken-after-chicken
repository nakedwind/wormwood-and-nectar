  }

  if (!G.keys) return;
  G.keys[e.key] = true;

  // 撠店?湔嚗征?賡 / Enter ?券?
  if (G.actionSceneActive && (e.key === ' ' || e.key === 'Enter')) { ascAdvance(); return; }

  // ESC嚗?瘨?閰望??豢?嚗????銝? paused 敶梢嚗?
  if (e.key === 'Escape') {
    if (document.getElementById('save-panel-overlay').style.display === 'flex') { closeSavePanel(); return; }
    if (document.getElementById('cook-select-overlay').style.display === 'flex') closeCookSelect();
    else if (document.getElementById('action-overlay').style.display === 'flex') closeAction();
    else if (document.getElementById('dialogue-overlay').style.display === 'flex') closeDlg();
    return;
  }

  // 摮??Ｘ??嚗????局嚗???????Enter/蝛箇 蝣箄?
  if (document.getElementById('save-panel-overlay').style.display === 'flex') {
    if (e.key === 'ArrowUp')    { savePanelMoveFocus(-1, 0); return; }
    if (e.key === 'ArrowDown')  { savePanelMoveFocus(+1, 0); return; }
    if (e.key === 'ArrowLeft')  { savePanelMoveFocus(0, -1); return; }
    if (e.key === 'ArrowRight') { savePanelMoveFocus(0, +1); return; }
    if (e.key === ' ' || e.key === 'Enter') { savePanelConfirm(); return; }
    return;
  }

  // 憌?憭?Ｘ?????孵??萇宏?征??Enter ???Ⅱ隤?
  if (document.getElementById('cook-select-overlay').style.display === 'flex') {
    if (e.key === 'ArrowUp')   { cookSelectMoveCursor(-1); return; }
    if (e.key === 'ArrowDown') { cookSelectMoveCursor(+1); return; }
    if (e.key === ' ' || e.key === 'Enter') { cookSelectRunSelected(); return; }
    return;
  }

  // ?詨?????孵??萇宏?征??Enter 蝣箄?
  if (document.getElementById('action-overlay').style.display === 'flex') {
    if (e.key === 'ArrowUp')   { menuMoveCursor(-1); return; }
    if (e.key === 'ArrowDown') { menuMoveCursor(+1); return; }
    if (e.key === ' ' || e.key === 'Enter') { menuRunSelected(); return; }
    return;
  }

  if (G.paused || G.actionSceneActive) return;

  // 蝛箇?蛛?鈭?嚗??挂?萇??嚗?
  if (e.key === ' ') {
    e.preventDefault();
    // 撠店獢???嚗征?賡??摰?
    if (document.getElementById('dialogue-overlay').style.display === 'flex') { closeDlg(); return; }
    // ????批捆???芸??券脫???
    if (storyQueue.length > 0) { advanceStory(); return; }
    // ?血?閫貊?湔鈭?
    const zone = getActiveZone();
    const near = isNearAvaren();
    if (G.chicken.carried) {
      dropChicken();
    } else if (isNearChicken()) {
      pickupChicken();
    } else if (G.carryingSoup && isNearKitchenCounter()) {
      putDownSoup();
    } else if (G.carryingSoup && near && G.avarenScene === G.scene) {
      giveSoupToAvaren();
    } else if (G.carryingSoup && isNearReid()) {
      sellSoupToReid();
    } else if (G.scene === 'kitchen' && G.soupReady && isNearSoup() && !G.carryingSoup) {
      doSoupInteract();
    } else if (isNearFairy()) {
      G.fairyCaught = true;
      G.fairyItem++;
      renderHUD();
      toast('??憒移 +1');
    } else if (zone && zone.interactHint) {
      zone.fn();
    } else if (isNearReid()) {
      openRedMenu();
    } else if (near) {
      openAvarenMenu();
    }
  }
  // F: scene transition (?嚗粥?交??芸?閫貊)
  if (e.key === 'f' || e.key === 'F') {
    const zone = getActiveZone();
    if (zone && zone.isScene) zone.fn();
  }
  // ` ?蛛????日璅∪?
  if (e.key === '`') { if (G) G.debugMode = !G.debugMode; }
  // P ?蛛????湔?拐辣蝺刻摩??
  if (e.key === 'p' || e.key === 'P') { toggleSceneObjEditor(); }
