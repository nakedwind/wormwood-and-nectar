  if (soe.objects.length === 0) return;
  if (!confirm('蝣箏?皜??隞塚?')) return;
  soe.objects = [];
  document.querySelectorAll('.seo-obj').forEach(el => el.remove());
  soeUpdateList();
}

function soeCopyCode() {
  // ?暹??拐辣嚗??桀??湔??撠?摰孵嚗?  const container = soeGetExistContainer();
  const existLines = container ? Array.from(container.children).map(el => {
    const img = el.querySelector('img');
    if (!img) return '';
    const src  = img.getAttribute('src');
    const x    = parseInt(el.style.left) || 0;
    const y    = parseInt(el.style.top)  || 0;
    const w    = parseInt(el.style.width)  || 0;
    const h    = parseInt(el.style.height) || 0;
    const z    = parseInt(el.style.zIndex) || 10;
    const id   = el.id ? ` id="${el.id}"` : '';
    return `<div${id} style="position:absolute;left:${x}px;top:${y}px;width:${w}px;height:${h}px;z-index:${z};pointer-events:none;"><img src="${src}" style="width:100%;height:100%;object-fit:contain;image-rendering:pixelated;"></div>`;
  }).filter(Boolean) : [];
  // ?啣??拐辣
  const newLines = soe.objects.map(obj =>
    `<div style="position:absolute;left:${obj.x}px;top:${obj.y}px;width:${obj.w}px;height:${obj.h}px;z-index:${obj.z};pointer-events:none;"><img src="${obj.src}" style="width:100%;height:100%;object-fit:contain;image-rendering:pixelated;"></div>`
  );
  const lines = [...existLines, ...newLines];
  if (lines.length === 0) { alert('撠?遙雿隞?'); return; }
  navigator.clipboard.writeText(lines.join('\n')).then(() => {
    const msg = document.getElementById('soe-copy-msg');
    msg.style.display = 'inline';
    setTimeout(() => { msg.style.display = 'none'; }, 2000);
  });
}

function soeUpdateList() {
  const list = document.getElementById('soe-list');
  if (soe.objects.length === 0) {
    list.innerHTML = '<div class="soe-empty">嚗??芣憓遙雿隞塚?</div>';
    return;
  }
  list.innerHTML = soe.objects.map(obj => `
    <div class="soe-item">
      <span class="soe-item-name">${obj.src.split('/').pop().replace(/^bg_(outside|lobby|room|forest)_?/, '').replace('.png','')}</span>
      <span class="soe-item-pos">x:${obj.x} y:${obj.y}</span>
      <span class="soe-item-size">${obj.w}?${obj.h}</span>
      <span style="color:#c0a060;font-size:10px;width:36px;text-align:center;">z:${obj.z}</span>
      <button class="soe-item-del" style="color:#60a060;" onclick="soeChangeZ('${obj.id}',1)"  title="敺??撅?>??/button>
      <button class="soe-item-del" style="color:#6090c0;" onclick="soeChangeZ('${obj.id}',-1)" title="敺敺?撅?>??/button>
      <button class="soe-item-del" onclick="soeDelete('${obj.id}')" title="?芷">??/button>
    </div>
  `).join('');
}

function soeChangeZ(id, delta) {
  const obj = soe.objects.find(o => o.id === id);
  if (!obj) return;
  obj.z = Math.max(1, obj.z + delta);
  const el = document.getElementById(id);
  if (el) el.style.zIndex = obj.z;
  soeUpdateList();
}

function soeRenderObjects() {
  document.querySelectorAll('.seo-obj').forEach(el => el.remove());
  if (!soe.active) return;
  const wrap = document.getElementById('scene-wrap');
  soe.objects.forEach(obj => {
    const div = document.createElement('div');
    div.id = obj.id;
    div.className = 'seo-obj' + (obj.id === soe.selectedId ? ' selected' : '');
    div.style.left    = obj.x + 'px';
    div.style.top     = obj.y + 'px';
    div.style.width   = obj.w + 'px';
    div.style.height  = obj.h + 'px';
    div.style.zIndex  = obj.z;
    div.innerHTML = `
      <img src="${obj.src}" style="width:100%;height:100%;object-fit:contain;image-rendering:pixelated;pointer-events:none;display:block;">
      <div class="seo-label">${obj.src}?${obj.x}, ${obj.y}?${obj.w}?${obj.h}?z:${obj.z}</div>
      <div class="seo-resize"></div>
    `;
    // ??蝘餃?
    div.addEventListener('mousedown', e => {
      if (e.target.classList.contains('seo-resize')) return;
      e.preventDefault(); e.stopPropagation();
      soe.selectedId = obj.id;
      soeRenderObjects();
      const wrapRect = wrap.getBoundingClientRect();
      soe.dragging = {
        id: obj.id,
        startMX: e.clientX, startMY: e.clientY,
        startOX: obj.x,     startOY: obj.y,
        wrapLeft: wrapRect.left, wrapTop: wrapRect.top,
      };
    });
    // 蝮格
    div.querySelector('.seo-resize').addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation();
      soe.resizing = {
        id: obj.id,
        startMX: e.clientX, startMY: e.clientY,
        startW: obj.w, startH: obj.h,
      };
    });
    wrap.appendChild(div);
  });
}

document.addEventListener('mousemove', e => {
  if (soeExistDrag) {
    const d = soeExistDrag;
    const x = d.startX + (e.clientX - d.startMX);
    const y = d.startY + (e.clientY - d.startMY);
    d.el.style.left = x + 'px';
    d.el.style.top  = y + 'px';
    const label = d.el.querySelector('.soe-exist-label');
    if (label) {
      const srcShort = d.el.querySelector('img').getAttribute('src')
        .split('/').pop().replace(/^bg_(outside|lobby|room|forest)_?/, '').replace('.png','');
      label.textContent = `${srcShort}  ${x},${y}`;
    }
  }
  if (soe.dragging) {
    const d = soe.dragging;
    const obj = soe.objects.find(o => o.id === d.id);
    if (obj) {
      obj.x = d.startOX + (e.clientX - d.startMX);
      obj.y = d.startOY + (e.clientY - d.startMY);
      const el = document.getElementById(obj.id);
      if (el) {
        el.style.left = obj.x + 'px';
        el.style.top  = obj.y + 'px';
        el.querySelector('.seo-label').textContent =
          `${obj.src}?${obj.x}, ${obj.y}?${obj.w}?${obj.h}`;
      }
      soeUpdateList();
    }
  }
  if (soe.resizing) {
    const d = soe.resizing;
    const obj = soe.objects.find(o => o.id === d.id);
    if (obj) {
      obj.w = Math.max(10, d.startW + (e.clientX - d.startMX));
      obj.h = Math.max(10, d.startH + (e.clientY - d.startMY));
      const el = document.getElementById(obj.id);
      if (el) {
        el.style.width  = obj.w + 'px';
        el.style.height = obj.h + 'px';
        el.querySelector('.seo-label').textContent =
          `${obj.src}?${obj.x}, ${obj.y}?${obj.w}?${obj.h}`;
      }
      soeUpdateList();
    }
  }
});
document.addEventListener('mouseup', () => {
  soe.dragging = null;
  soe.resizing = null;
  soeExistDrag = null;
});

