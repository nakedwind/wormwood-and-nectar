function isNearReid() {
  if (G.scene !== 'outside' || G.day % 2 === 0 || G.timePeriod !== 'morning') return false;
  return Math.hypot(G.red.x - G.eldrin.x, G.red.y - G.eldrin.y) < 75;
}

function isNearFairy() {
  if (G.fairyCaught || G.scene !== 'forest' || G.timePeriod !== 'evening' || G.day % 2 !== 0) return false;
  return Math.hypot(G.eldrin.x - G.fairy.x, G.eldrin.y - G.fairy.y) < 65;
}

