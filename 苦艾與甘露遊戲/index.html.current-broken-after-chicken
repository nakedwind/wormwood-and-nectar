const FOREST_DEPTH_OBJECTS = [
  'forest-light-1', 'forest-fishing-1',
  'forest-grass-1', 'forest-grass-2', 'forest-grass-3',
  'forest-grass-4', 'forest-grass-5', 'forest-grass-6',
  'forest-tree-1', 'forest-tree-2', 'forest-tree-3',
  'forest-tree-4', 'forest-tree-5', 'forest-tree-6',
];
const FOREST_DEPTH_ANCHORS = {};

function updateForestDepth() {
  if (G.scene !== 'forest') return;
  const charZ = 13;
  FOREST_DEPTH_OBJECTS.forEach(id => {
    const obj = document.getElementById(id);
    if (!obj) return;
    if (!obj.dataset.baseZ) obj.dataset.baseZ = String(parseInt(obj.style.zIndex, 10) || 10);
    const baseZ = parseInt(obj.dataset.baseZ, 10) || 10;
    const top = parseFloat(obj.style.top) || 0;
    const height = parseFloat(obj.style.height) || 0;
    const anchorRatio = FOREST_DEPTH_ANCHORS[id] || 0.9;
    const anchor = top + height * anchorRatio;
    obj.style.zIndex = G.eldrin.y <= anchor ? String(charZ + 2) : String(Math.min(baseZ, charZ - 1));
  });
}

function doNightFade(cb) {
  const el = document.getElementById('night-fade');
  el.style.transition = 'none';
  el.style.opacity = '0';
  el.style.display = 'block';
  el.getBoundingClientRect();
  el.style.transition = 'opacity 0.7s ease';
  el.style.opacity = '1';
  setTimeout(() => {
    cb();
    setTimeout(() => {
      el.style.opacity = '0';
      setTimeout(() => { el.style.display = 'none'; }, 700);
    }, 80);
  }, 700);
}

function crossfadeBackground(newUrl) {
  const base = document.getElementById('scene-bg');
  const top  = document.getElementById('scene-bg-top');
  top.style.transition = 'none';
  top.style.opacity = '0';
  top.style.backgroundImage = `url('${newUrl}')`;
  top.getBoundingClientRect();
  top.style.transition = 'opacity 1.5s ease';
  top.style.opacity = '1';
  setTimeout(() => {
    base.style.backgroundImage = `url('${newUrl}')`;
    top.style.transition = 'none';
    top.style.opacity = '0';
  }, 1500);
}

