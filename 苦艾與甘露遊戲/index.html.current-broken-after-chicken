function useTime(h) {
  G.timeUsed = Math.min(G.timeUsed + h, DAY_HOURS);
  renderTime();
  if (G.timeUsed >= DAY_HOURS) endDay();
}

function currentTimeStr() {
  const totalMins = START_HOUR * 60 + G.timeUsed * 60;
  const hh = Math.floor(totalMins / 60);
  const mm = Math.floor(totalMins % 60);
  return String(hh).padStart(2,'0') + ':' + String(mm).padStart(2,'0');
}

function renderTime(elapsed) {
  if (elapsed === undefined) elapsed = (performance.now() - G.dayStartMs) / 1000;
  const pct = Math.min(elapsed / DAY_REAL_SECONDS * 100, 100);
  document.getElementById('time-bar').style.width = pct + '%';
  // 07:00??2:00 = 900??嚗???480 蝘?  const gameMin = elapsed * (900 / DAY_REAL_SECONDS);
  const hh = Math.min(22, Math.floor(7 + gameMin / 60));
  const t = String(hh).padStart(2,'0') + ':00';
  document.getElementById('time-label').textContent = t;
  document.getElementById('time-clock').textContent = t;
  const isMorning = G.timePeriod === 'morning';
  const secLeft = isMorning
    ? Math.max(0, Math.ceil(MORNING_SECONDS - elapsed))
    : Math.max(0, Math.ceil(DAY_REAL_SECONDS - elapsed));
  document.getElementById('time-remaining').textContent =
    (isMorning ? '? ?拐?' : '?? ??') + '??拚? ' + secLeft + ' 蝘?';
  document.getElementById('period-badge').textContent = isMorning ? '? ?拐?' : '?? ??';
  const skipBtn = document.getElementById('btn-skip-evening');
  if (skipBtn) skipBtn.style.display = isMorning ? 'block' : 'none';
}

