(function initZoneEditor() {
  const overlay = document.getElementById('ze-overlay');

  overlay.addEventListener('mousedown', e => {
    const rect = overlay.getBoundingClientRect();
    zeX0 = Math.round(e.clientX - rect.left);
    zeY0 = Math.round(e.clientY - rect.top);
    zeDrawing = true;
    const r = document.getElementById('ze-rect');
    r.style.left = zeX0 + 'px'; r.style.top = zeY0 + 'px';
    r.style.width = '0'; r.style.height = '0';
    r.style.display = 'block';
    document.getElementById('ze-label').textContent = '';
  });

  overlay.addEventListener('mousemove', e => {
    if (!zeDrawing) return;
    const rect = overlay.getBoundingClientRect();
    const x = Math.round(e.clientX - rect.left);
    const y = Math.round(e.clientY - rect.top);
    const x1 = Math.min(x, zeX0), y1 = Math.min(y, zeY0);
    const x2 = Math.max(x, zeX0), y2 = Math.max(y, zeY0);
    const r = document.getElementById('ze-rect');
    r.style.left = x1 + 'px'; r.style.top  = y1 + 'px';
    r.style.width  = (x2 - x1) + 'px';
    r.style.height = (y2 - y1) + 'px';
    document.getElementById('ze-label').textContent =
      `x1:${x1}  y1:${y1}  x2:${x2}  y2:${y2}`;
  });

  overlay.addEventListener('mouseup', e => {
    if (!zeDrawing) return;
    zeDrawing = false;
    const rect = overlay.getBoundingClientRect();
    const x = Math.round(e.clientX - rect.left);
    const y = Math.round(e.clientY - rect.top);
    const x1 = Math.min(x, zeX0), y1 = Math.min(y, zeY0);
    const x2 = Math.max(x, zeX0), y2 = Math.max(y, zeY0);
    if (x2 - x1 > 5 && y2 - y1 > 5) {
      zeRects.push({ x1, y1, x2, y2 });
      zeUpdatePanel();
    } else {
      document.getElementById('ze-rect').style.display = 'none';
    }
  });
})();

