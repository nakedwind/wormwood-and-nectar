function updateOutsideDepth() {
  if (G.scene !== 'outside') return;
  const charZ = 13;
  OUTSIDE_DEPTH_OBJECTS.forEach(id => {
    const obj = document.getElementById(id);
    if (!obj) return;
    if (!obj.dataset.baseZ) obj.dataset.baseZ = String(parseInt(obj.style.zIndex, 10) || 8);
    const baseZ = parseInt(obj.dataset.baseZ, 10) || 8;
    const top = parseFloat(obj.style.top) || 0;
    const height = parseFloat(obj.style.height) || 0;
    const anchorRatio = OUTSIDE_DEPTH_ANCHORS[id] || 0.9;
    const anchor = top + height * anchorRatio;
    obj.style.zIndex = G.eldrin.y <= anchor ? String(charZ + 2) : String(Math.min(baseZ, charZ - 1));
  });
}

