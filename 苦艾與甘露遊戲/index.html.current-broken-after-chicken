//   10,9   ???? ??
//   8,7,6,5???? ?券?
//   4,3,2,1???? ??
function updateBlinkOverlay(name, pose, walkFrame, dispH, blinkCount) {
  const blinkEl = document.getElementById('blink-' + name);
  if (!blinkEl) return;
  if (!blinkCount) { blinkEl.style.display = 'none'; return; }
  const info = spriteInfo[name];
  if (!info) return;
  const bsi   = blinkSpriteInfo[name];
  const scale = dispH / info.fh;
  const fw    = info.fw * scale;
  const fh    = dispH;
  const url   = bsi ? bsi.url : ('character_' + name + '_blink.png');
  const type  = bsi ? bsi.type : 'singlecol';

  // div 撠箏站?箏??箏?潘???char-wrap 摰??嚗?  blinkEl.style.width  = fw + 'px';
  blinkEl.style.height = fh + 'px';
  blinkEl.style.left   = '0';
  blinkEl.style.top    = '0';
  blinkEl.style.backgroundRepeat = 'no-repeat';

  // ?函??嚗?0,9????1)  8,7,6,5???2)  4,3,2,1????1)
  let blinkRow;
  if (blinkCount >= 9)      blinkRow = 1;
  else if (blinkCount >= 5) blinkRow = 2;
  else                      blinkRow = 1;

  if (info.blinkCol >= 0) {
    // ?? ?批??函甈?銝餃?蝚昧甈?嚗?朣?00%嚗???宏 ??
    if (pose !== 'front') { blinkEl.style.display = 'none'; return; }
    const mainUrl  = 'character_' + name + '.png';
    const mainCols = info.cols;
    blinkEl.style.backgroundImage    = 'url(' + mainUrl + ')';
    blinkEl.style.backgroundSize     = (fw * mainCols) + 'px ' + (fh * SPRITE_ROWS_N) + 'px';
    blinkEl.style.backgroundPosition = (-info.blinkCol * fw) + 'px ' + (-blinkRow * fh) + 'px';
  } else if (type === 'fullsheet') {
    // 摰?函? 4?3 spritesheet
    const col = POSE_COL[pose];
    blinkEl.style.backgroundImage    = 'url(' + url + ')';
    blinkEl.style.backgroundSize     = (fw * SPRITE_COLS) + 'px ' + (fh * SPRITE_ROWS_N) + 'px';
    blinkEl.style.backgroundPosition = (-col * fw) + 'px ' + (-blinkRow * fh) + 'px';
  } else if (type === 'singlecol') {
    // single-column blink sheet.
    if (pose !== 'front') { blinkEl.style.display = 'none'; return; }
    blinkEl.style.backgroundImage    = 'url(' + url + ')';
    blinkEl.style.backgroundSize     = fw + 'px ' + (fh * SPRITE_ROWS_N) + 'px';
    blinkEl.style.backgroundPosition = '0px ' + (-blinkRow * fh) + 'px';
  } else {
    // ?桐??澆?
    blinkEl.style.backgroundImage    = 'url(' + url + ')';
    blinkEl.style.backgroundSize     = fw + 'px ' + fh + 'px';
    blinkEl.style.backgroundPosition = '0px 0px';
  }
  blinkEl.style.display = 'block';
}

