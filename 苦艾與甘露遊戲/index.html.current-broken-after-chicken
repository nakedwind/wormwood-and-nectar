function pickGatherItem() {
  const total = GATHER_ITEMS.reduce((s,i) => s + i.weight, 0);
  let r = Math.random() * total;
  for (const item of GATHER_ITEMS) { r -= item.weight; if (r <= 0) return item; }
  return GATHER_ITEMS[0];
}

function triggerAvarenGather() {
  const item = pickGatherItem();
  const effectLine = item.effectText ? `\n（${item.effectText}）` : '';
  showEvent('採集', '阿瓦倫找到了一點東西', `他從草叢裡拿出：${item.name}\n${item.desc}${effectLine}`, () => {
